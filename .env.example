# CueTasks — cloud sync (optional). Copy to .env.local and fill in.
# Both values are safe for the browser (the anon key is protected by RLS).
# NEVER put the Supabase service_role key here — that stays server-side only.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Web Push (background reminders). The PUBLIC VAPID key only — it's meant for
# the browser. The private key is a Supabase Edge Function secret, never here.
VITE_VAPID_PUBLIC_KEY=
